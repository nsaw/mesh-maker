#!/usr/bin/env sh

# =============================================================================
# Pre-commit hook: Secret & credential leak prevention
# Scans staged files for API keys, tokens, passwords, database URLs, and
# other sensitive patterns before allowing a commit.
# =============================================================================

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

# Temp file to track whether we found anything (avoids subshell scoping issues)
RESULT_FILE=$(mktemp)
echo "0" > "$RESULT_FILE"

# Files to always skip (binary, lock files, the hook itself)
SKIP_PATTERN='\.(png|jpg|jpeg|gif|ico|woff2?|ttf|eot|svg|mp4|zip|tar|gz)$|package-lock\.json$|\.husky/'

scan_for_pattern() {
  local label="$1"
  local pattern="$2"
  local file="$3"
  local content="$4"

  MATCHES=$(echo "$content" | grep -nE -- "$pattern" 2>/dev/null || true)
  if [ -n "$MATCHES" ]; then
    if [ "$(cat "$RESULT_FILE")" = "0" ]; then
      echo ""
      echo "============================================================"
      echo "  COMMIT BLOCKED — Potential secrets detected"
      echo "============================================================"
      echo "1" > "$RESULT_FILE"
    fi
    echo ""
    echo "  [$label] in $file:"
    echo "$MATCHES" | head -5 | sed 's/^/    line /'
    MATCH_COUNT=$(echo "$MATCHES" | wc -l | tr -d ' ')
    if [ "$MATCH_COUNT" -gt 5 ]; then
      echo "    ... and $((MATCH_COUNT - 5)) more matches"
    fi
  fi
}

for FILE in $STAGED_FILES; do
  # Skip binary/lock files
  echo "$FILE" | grep -qE "$SKIP_PATTERN" && continue

  # Get staged content (not working tree) for accurate scanning
  CONTENT=$(git show ":$FILE" 2>/dev/null) || continue

  # Strip known-safe CDN URLs to avoid false positives on embedded UUIDs/hashes
  CONTENT=$(echo "$CONTENT" | grep -v 'imagedelivery\.net' || true)

  # --- Cloud provider keys ---
  scan_for_pattern "AWS_ACCESS_KEY" \
    "AKIA[0-9A-Z]{16}" \
    "$FILE" "$CONTENT"

  scan_for_pattern "AWS_SECRET_KEY" \
    "['\"][0-9a-zA-Z/+]{40}['\"]" \
    "$FILE" "$CONTENT"

  scan_for_pattern "GOOGLE_API_KEY" \
    "AIza[0-9A-Za-z_-]{35}" \
    "$FILE" "$CONTENT"

  scan_for_pattern "CLOUDFLARE_API_KEY" \
    "[0-9a-f]{37}" \
    "$FILE" "$CONTENT"

  # --- Platform tokens ---
  scan_for_pattern "GITHUB_TOKEN" \
    "(ghp|gho|ghu|ghs|ghr)_[0-9a-zA-Z]{36,}" \
    "$FILE" "$CONTENT"

  scan_for_pattern "SLACK_TOKEN" \
    "xox[bporas]-[0-9a-zA-Z-]{10,}" \
    "$FILE" "$CONTENT"

  scan_for_pattern "SLACK_WEBHOOK" \
    "hooks\.slack\.com/services/T[0-9A-Z]{8,}/B[0-9A-Z]{8,}/[0-9a-zA-Z]{24}" \
    "$FILE" "$CONTENT"

  scan_for_pattern "STRIPE_KEY" \
    "(sk|pk)_(test|live)_[0-9a-zA-Z]{24,}" \
    "$FILE" "$CONTENT"

  scan_for_pattern "TWILIO_KEY" \
    "SK[0-9a-fA-F]{32}" \
    "$FILE" "$CONTENT"

  scan_for_pattern "SENDGRID_KEY" \
    "SG\.[0-9a-zA-Z_.+-]{22,}\.[0-9a-zA-Z_.+-]{22,}" \
    "$FILE" "$CONTENT"

  scan_for_pattern "NPM_TOKEN" \
    "npm_[0-9a-zA-Z]{36}" \
    "$FILE" "$CONTENT"

  scan_for_pattern "PYPI_TOKEN" \
    "pypi-[0-9a-zA-Z_-]{50,}" \
    "$FILE" "$CONTENT"

  # --- Generic secrets ---
  scan_for_pattern "GENERIC_API_KEY" \
    "(api[_-]?key|apikey)[[:space:]]*[:=][[:space:]]*[\"'][0-9a-zA-Z_./-]{16,}" \
    "$FILE" "$CONTENT"

  scan_for_pattern "GENERIC_SECRET" \
    "(secret|token|password|passwd|pwd)[[:space:]]*[:=][[:space:]]*[\"'][^[:space:]\"']{8,}" \
    "$FILE" "$CONTENT"

  scan_for_pattern "GENERIC_TOKEN" \
    "(access_token|auth_token|refresh_token)[[:space:]]*[:=][[:space:]]*[\"'][^[:space:]\"']{8,}" \
    "$FILE" "$CONTENT"

  # --- Database URLs ---
  scan_for_pattern "DATABASE_URL" \
    "(postgres|mysql|mongodb|redis|amqp|mssql)://[^[:space:]\"']{10,}" \
    "$FILE" "$CONTENT"

  scan_for_pattern "CONNECTION_STRING" \
    "(Server|Data Source|Initial Catalog|User ID)=.*Password=" \
    "$FILE" "$CONTENT"

  # --- Private keys ---
  scan_for_pattern "PRIVATE_KEY" \
    "-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY-----" \
    "$FILE" "$CONTENT"

  # --- Auth headers ---
  scan_for_pattern "BEARER_TOKEN" \
    "Bearer[[:space:]]+[0-9a-zA-Z_.~+/-]{20,}" \
    "$FILE" "$CONTENT"

  scan_for_pattern "BASIC_AUTH" \
    "Basic[[:space:]]+[A-Za-z0-9+/=]{20,}" \
    "$FILE" "$CONTENT"

  # --- JWT ---
  scan_for_pattern "JWT_TOKEN" \
    "eyJ[0-9a-zA-Z_-]{10,}\.eyJ[0-9a-zA-Z_-]{10,}\.[0-9a-zA-Z_-]{10,}" \
    "$FILE" "$CONTENT"

  # --- HEROKU ---
  scan_for_pattern "HEROKU_API_KEY" \
    "HEROKU[_-]?(API[_-]?KEY|TOKEN|SECRET)[[:space:]]*[:=][[:space:]]*[\"']?[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}" \
    "$FILE" "$CONTENT"
done

BLOCKED=$(cat "$RESULT_FILE")
rm -f "$RESULT_FILE"

if [ "$BLOCKED" = "1" ]; then
  echo ""
  echo "------------------------------------------------------------"
  echo "  To commit anyway (false positive), use:"
  echo "    git commit --no-verify"
  echo "------------------------------------------------------------"
  echo ""
  exit 1
fi

exit 0
