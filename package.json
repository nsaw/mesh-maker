{
  "name": "meshcraft",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "deploy": "npm run build && node -e \"for (const k of ['CLOUDFLARE_API_TOKEN','CLOUDFLARE_ACCOUNT_ID']) { if (!process.env[k]) { console.error(k + ' is required'); process.exit(1); } }\" && npx wrangler@4 pages deploy dist --project-name=meshcraft --branch=main",
    "typecheck": "tsc --noEmit",
    "typecheck:cli": "tsc -p tsconfig.cli.json --noEmit",
    "lint": "eslint src/ cli/",
    "lint:fix": "eslint src/ cli/ --fix",
    "stl-to-sbp": "tsx cli/stl-to-sbp.ts",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "husky": "^9.1.7",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.57.1",
    "vite": "^6.0.0",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^22.0.0",
    "better-sqlite3": "^12.8.0",
    "tsx": "^4.19.0"
  }
}
